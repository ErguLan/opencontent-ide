# ============================================
# OpenContent IDE — Environment Configuration
# ============================================
# Copy this file to .env and add your keys.
# All keys are optional. The app works without any.

# ── AI Providers (pick at least one) ─────────

# OpenRouter API (recommended — access to 200+ models)
# Get your free key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Google Gemini API (optional — for image generation)
# Get your free key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# OpenAI API (optional — for GPT-4 Vision, DALL-E)
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# ── Local Models (Ollama) ────────────────────

# Point to your local Ollama instance for 100% offline usage
# Install Ollama: https://ollama.com
VITE_OLLAMA_BASE_URL=http://localhost:11434

# ── App Configuration ────────────────────────

VITE_APP_NAME=OpenContent IDE
VITE_APP_VERSION=0.1.0

# Enable usage limits (for self-hosted SaaS forks)
# Set to "true" to activate freemium limits
VITE_ENABLE_USAGE_LIMITS=false

# Request timeout in milliseconds (default: 45000)
VITE_AI_REQUEST_TIMEOUT_MS=45000
